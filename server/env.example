# server/.env
# Copy this to .env and fill in your values.

PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Firebase project (matches your serviceAccountKey.json)
FIREBASE_PROJECT_ID=storage-17950

# Gmail (Nodemailer) — sends trip ticket confirmation emails
# 1. Enable 2-Step Verification on the Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password below (spaces are fine)
GMAIL_USER=your-account@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Cloudflare Turnstile — verifies the CAPTCHA token from login/register
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
